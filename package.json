{
  "name": "@kstawinski/uuidv7",
  "version": "1.0.0",
  "description": "Ultra-fast, RFC 9562 compliant UUIDv7 generator for Node.js, browsers, and edge runtimes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx bench/benchmark.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uuid",
    "uuidv7",
    "uuid-v7",
    "rfc9562",
    "sortable",
    "unique-id",
    "identifier"
  ],
  "author": "Kacper Stawiński",
  "license": "MIT",
  "devDependencies": {
    "tinybench": "^6.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "nanoid": "^5.1.7",
    "uuid": "^13.0.0",
    "uuidv7": "^1.2.1"
  }
}
